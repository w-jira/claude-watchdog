#!/bin/bash
# claude-tele-macos — launchd/tmux lifecycle manager for Claude Code Telegram.
set -euo pipefail

readonly SESSION="telegram-claude"
readonly LABEL="com.claude-watchdog.telegram"
readonly PLIST="${HOME}/Library/LaunchAgents/${LABEL}.plist"
readonly STATE_DIR="${HOME}/.claude/channels/telegram"
readonly WORKDIR="${STATE_DIR}/workdir"
readonly BOT_PID_FILE="${STATE_DIR}/bot.pid"
readonly OUT_LOG="${STATE_DIR}/launchd.out.log"
readonly ERR_LOG="${STATE_DIR}/launchd.err.log"

if [ -x "${HOME}/.local/bin/claude" ]; then
  readonly CLAUDE_BIN="${HOME}/.local/bin/claude"
elif _resolved_claude="$(command -v claude 2>/dev/null)"; then
  readonly CLAUDE_BIN="$_resolved_claude"
else
  readonly CLAUDE_BIN="${HOME}/.local/bin/claude"
fi

RED=""; GREEN=""; YELLOW=""; BLUE=""; RESET=""
if [ -t 1 ] || [ -t 2 ]; then
  RED=$'\e[31m'; GREEN=$'\e[32m'; YELLOW=$'\e[33m'; BLUE=$'\e[34m'; RESET=$'\e[0m'
fi

die()  { echo "${RED}error:${RESET} $*" >&2; exit 1; }
warn() { echo "${YELLOW}warn:${RESET} $*" >&2; }
ok()   { echo "${GREEN}✓${RESET} $*"; }
info() { echo "${BLUE}→${RESET} $*"; }
need() { command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"; }

mkdir -p "$STATE_DIR" "$WORKDIR" && chmod 700 "$STATE_DIR" "$WORKDIR"

service_loaded() { launchctl print "gui/$(id -u)/${LABEL}" >/dev/null 2>&1; }
session_exists() { tmux has-session -t "$SESSION" 2>/dev/null; }

bun_alive() {
  local pid
  if [ -r "$BOT_PID_FILE" ]; then
    pid=$(cat "$BOT_PID_FILE" 2>/dev/null || true)
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
      ps -p "$pid" -o comm= 2>/dev/null | grep -qE '(^|/)bun$' && return 0
    fi
  fi
  pgrep -fl 'bun.*claude-plugins-official/telegram' >/dev/null 2>&1
}

write_plist() {
  mkdir -p "${HOME}/Library/LaunchAgents"
  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>${LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${HOME}/bin/claude-tele</string>
    <string>__exec-start</string>
  </array>
  <key>WorkingDirectory</key><string>${WORKDIR}</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>${OUT_LOG}</string>
  <key>StandardErrorPath</key><string>${ERR_LOG}</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key><string>${HOME}</string>
    <key>PATH</key><string>${HOME}/bin:${HOME}/.bun/bin:${HOME}/.local/bin:${HOME}/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>LANG</key><string>en_US.UTF-8</string>
    <key>LC_ALL</key><string>en_US.UTF-8</string>
    <key>TERM</key><string>xterm-256color</string>
  </dict>
</dict>
</plist>
EOF
  chmod 600 "$PLIST"
}

accept_first_run_prompts() {
  local i trust_done=0 bypass_done=0 pane
  for i in $(seq 1 60); do
    pane=$(tmux capture-pane -t "$SESSION" -p -S -40 2>/dev/null || true)
    if [ "$trust_done" = 0 ] && printf '%s\n' "$pane" | grep -qE "trust the files|trust this folder|Is this a project you created"; then
      tmux send-keys -t "$SESSION" -- Enter
      echo "folder-trust prompt accepted"
      trust_done=1
      sleep 1
      continue
    fi
    if [ "$bypass_done" = 0 ] && printf '%s\n' "$pane" | grep -q "Bypass Permissions mode"; then
      tmux send-keys -t "$SESSION" -- "2"
      sleep 1
      tmux send-keys -t "$SESSION" -- Enter
      echo "bypass-permissions prompt accepted"
      bypass_done=1
      sleep 1
      continue
    fi
    if printf '%s\n' "$pane" | tail -6 | grep -qE '^❯[[:space:]]*$'; then
      break
    fi
    sleep 1
  done
}

cmd_exec_start() {
  need tmux
  [ -x "$CLAUDE_BIN" ] || die "claude binary missing: $CLAUDE_BIN"
  if session_exists; then
    warn "stale tmux session '${SESSION}' — killing"
    tmux kill-session -t "$SESSION" 2>/dev/null || true
  fi

  local resume_flag=""
  local slug="${WORKDIR//\//-}"
  slug="${slug//./-}"
  if compgen -G "${HOME}/.claude/projects/${slug}/"'*.jsonl' >/dev/null; then
    resume_flag="--continue"
    echo "resuming previous telegram conversation"
  else
    echo "no prior transcript — starting fresh session"
  fi

  local -a argv=("$CLAUDE_BIN" --dangerously-skip-permissions)
  [ -n "$resume_flag" ] && argv+=("$resume_flag")
  argv+=(--channels "plugin:telegram@claude-plugins-official")
  local cmd_str
  printf -v cmd_str '%q ' "${argv[@]}"
  tmux new-session -d -s "$SESSION" -c "$WORKDIR" -- "$cmd_str"
  accept_first_run_prompts
  echo "started (resume=${resume_flag:-no})"
  trap 'echo "exec-start: received signal"; exit 0' TERM INT
  while session_exists; do sleep 5; done
  echo "tmux session ended — exec-start returning"
}

cmd_exec_stop() {
  session_exists || { echo "already stopped"; return 0; }
  tmux send-keys -t "$SESSION" -- C-c 2>/dev/null || true
  sleep 0.5
  tmux send-keys -t "$SESSION" -- C-c 2>/dev/null || true
  sleep 3
  session_exists && tmux kill-session -t "$SESSION" 2>/dev/null || true
  echo "stopped"
}

cmd_start() {
  write_plist
  if service_loaded; then
    launchctl kickstart -k "gui/$(id -u)/${LABEL}"
  else
    launchctl bootstrap "gui/$(id -u)" "$PLIST"
  fi
  sleep 3
  service_loaded || die "launchd service failed to load — run: claude-tele logs"
  ok "service started"
}

cmd_stop() {
  if service_loaded; then
    launchctl bootout "gui/$(id -u)" "$PLIST" || true
  fi
  cmd_exec_stop >/dev/null 2>&1 || true
  ok "stopped"
}

cmd_restart() { cmd_stop; cmd_start; }

cmd_status() {
  echo "${BLUE}── claude-tele macOS status ──${RESET}"
  service_loaded && ok "launchd: loaded" || echo "${YELLOW}○ launchd: not loaded${RESET}"
  session_exists && ok "tmux:    '${SESSION}' present" || echo "${RED}✗ tmux:    '${SESSION}' missing${RESET}"
  [ -x "$CLAUDE_BIN" ] && ok "claude:  ${CLAUDE_BIN}" || echo "${RED}✗ claude:  missing at ${CLAUDE_BIN}${RESET}"
  bun_alive && ok "bun:     plugin bridge running" || echo "${YELLOW}○ bun:     not detected${RESET}"
}

cmd_attach() { session_exists || die "session not running · start with: claude-tele start"; exec tmux attach -t "$SESSION"; }
cmd_logs() { tail -n 100 ${1:-} "$OUT_LOG" "$ERR_LOG" 2>/dev/null || true; }
cmd_heal() { if ! bun_alive; then warn "bun bridge missing — restarting"; cmd_restart; else ok "nothing to heal"; fi; }
cmd_doctor() {
  echo "${BLUE}── claude-tele macOS doctor ──${RESET}"
  need tmux; ok "tmux installed"
  bun --version >/dev/null 2>&1 && ok "bun runs" || die "bun missing or broken"
  [ -x "$CLAUDE_BIN" ] && ok "claude binary at ${CLAUDE_BIN}" || die "claude binary missing: ${CLAUDE_BIN}"
  [ -f "${STATE_DIR}/.env" ] && ok "bot .env present" || die "missing ${STATE_DIR}/.env"
  [ -f "${STATE_DIR}/access.json" ] && ok "access.json present" || die "missing ${STATE_DIR}/access.json"
  compgen -G "${HOME}/.claude/plugins/cache/*/telegram" >/dev/null && ok "telegram plugin installed" || die "telegram plugin missing"
  ok "all checks passed"
}

case "${1:-status}" in
  start) cmd_start ;;
  stop) cmd_stop ;;
  restart) cmd_restart ;;
  status) cmd_status ;;
  attach) cmd_attach ;;
  logs) shift; cmd_logs "$@" ;;
  heal) cmd_heal ;;
  doctor) cmd_doctor ;;
  __exec-start) cmd_exec_start ;;
  __exec-stop) cmd_exec_stop ;;
  help|-h|--help) sed -n '1,260p' "$0" | sed -n '1,40p' ;;
  *) die "unknown command: $1" ;;
esac
