#!/usr/bin/env python3
"""Replay Telegram messages journaled by claude-tele but absent from Claude transcripts.

The Telegram Bot API cannot retrieve confirmed history. The plugin patch journals
allowed inbound messages before handing them to Claude. If the MCP notification
fails or Claude restarts before consuming it, this tool can inject a synthetic
<channel> block into the live tmux session so Claude knows what it missed.
"""

from __future__ import annotations

import argparse
import html
import json
import os
import re
import subprocess
import sys
import tempfile
import time
from pathlib import Path
from typing import Any

SESSION = os.environ.get("CLAUDE_TELE_SESSION", "telegram-claude")
TMUX_RUNTIME_DIR = Path(os.environ.get("TMUX_TMPDIR", Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "claude-tele"))
TMUX_RUNTIME_DIR.mkdir(mode=0o700, parents=True, exist_ok=True)
os.environ["TMUX_TMPDIR"] = str(TMUX_RUNTIME_DIR)
STATE_DIR = Path(os.environ.get("TELEGRAM_STATE_DIR", Path.home() / ".claude" / "channels" / "telegram"))
WORKDIR = Path(os.environ.get("CLAUDE_TELE_WORKDIR", STATE_DIR / "workdir"))
JOURNAL_FILE = Path(os.environ.get("CLAUDE_TELE_INBOUND_JOURNAL", STATE_DIR / "inbound-journal.jsonl"))
ACK_FILE = Path(os.environ.get("CLAUDE_TELE_REPLAY_ACK", STATE_DIR / "replayed-inbound.jsonl"))
HEALTH_FILE = Path(os.environ.get("CLAUDE_TELE_PLUGIN_HEALTH", STATE_DIR / "plugin-health.json"))
MIN_AGE_SECONDS = int(os.environ.get("CLAUDE_TELE_REPLAY_MIN_AGE", "30"))
MAX_REPLAY = int(os.environ.get("CLAUDE_TELE_REPLAY_MAX", "20"))
HEALTH_MAX_AGE_SECONDS = int(os.environ.get("CLAUDE_TELE_HEALTH_MAX_AGE", "1200"))


def project_slug(path: Path) -> str:
  return str(path).replace("/", "-").replace(".", "-")


def transcript_dir() -> Path:
  return Path.home() / ".claude" / "projects" / project_slug(WORKDIR)


def load_jsonl(path: Path) -> list[dict[str, Any]]:
  if not path.exists():
    return []
  rows: list[dict[str, Any]] = []
  with path.open("r", encoding="utf-8", errors="replace") as f:
    for line in f:
      line = line.strip()
      if not line:
        continue
      try:
        parsed = json.loads(line)
      except json.JSONDecodeError:
        continue
      if isinstance(parsed, dict):
        rows.append(parsed)
  return rows


def message_key(row: dict[str, Any]) -> str | None:
  meta = row.get("meta")
  if not isinstance(meta, dict):
    return None
  chat_id = meta.get("chat_id")
  message_id = meta.get("message_id")
  if chat_id is None or message_id is None:
    return None
  return f"{chat_id}:{message_id}"


def delivered_keys_from_transcripts() -> set[str]:
  keys: set[str] = set()
  tdir = transcript_dir()
  if not tdir.exists():
    return keys
  # Read newest first; all top-level jsonl files are expected to be Telegram workdir transcripts.
  for path in sorted(tdir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True):
    try:
      text = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
      continue
    for chat_id, message_id in re.findall(r'<channel\b[^>]*\bchat_id="([^"]+)"[^>]*\bmessage_id="([^"]+)"', text):
      keys.add(f"{html.unescape(chat_id)}:{html.unescape(message_id)}")
  return keys


def replayed_keys() -> set[str]:
  return {key for row in load_jsonl(ACK_FILE) if (key := message_key(row))}


def _health_ts(health: dict[str, Any], key: str) -> int:
  try:
    return int(health.get(key) or 0)
  except (TypeError, ValueError):
    return 0


def telegram_e2e_healthy(now: int | None = None) -> tuple[bool, str]:
  """Return whether it is safe to inject into Claude's live Telegram session.

  Missed-message replay bypasses the Telegram plugin by pasting directly into
  tmux. Fail closed unless the watchdog has recently proven the Telegram Bot
  API is reachable and the plugin has started polling. This prevents restart or
  heal loops from repeatedly injecting old messages while Telegram delivery is
  broken.
  """
  if os.environ.get("CLAUDE_TELE_DISABLE_E2E_INJECTION_GATE") == "1":
    return True, "gate_disabled"

  now = int(time.time()) if now is None else now
  try:
    health = json.loads(HEALTH_FILE.read_text(encoding="utf-8"))
  except FileNotFoundError:
    return False, "health_missing"
  except (OSError, json.JSONDecodeError):
    return False, "health_unreadable"
  if not isinstance(health, dict):
    return False, "health_invalid"

  polling_started_at = _health_ts(health, "polling_started_at")
  if polling_started_at <= 0:
    return False, "polling_not_started"
  service_started_at = _health_ts(health, "service_started_at")
  if service_started_at > 0 and polling_started_at < service_started_at:
    return False, "polling_before_service_start"

  last_getme_ok_at = _health_ts(health, "last_getme_ok_at")
  if last_getme_ok_at <= 0:
    return False, "getme_never_ok"
  if service_started_at > 0 and last_getme_ok_at < service_started_at:
    return False, "getme_before_service_start"
  if now - last_getme_ok_at > HEALTH_MAX_AGE_SECONDS:
    return False, "getme_stale"

  last_getme_error_at = _health_ts(health, "last_getme_error_at")
  if last_getme_error_at > last_getme_ok_at:
    return False, "getme_error_after_ok"

  last_mcp_notify_ok_at = _health_ts(health, "last_mcp_notify_ok_at")
  last_mcp_notify_error_at = _health_ts(health, "last_mcp_notify_error_at")
  if last_mcp_notify_error_at > last_mcp_notify_ok_at:
    return False, "mcp_notify_error_after_ok"

  if health.get("last_error") and last_mcp_notify_error_at >= max(last_mcp_notify_ok_at, last_getme_ok_at):
    return False, "recent_error"

  return True, "ok"


def pending_rows() -> list[dict[str, Any]]:
  now = int(time.time())
  delivered = delivered_keys_from_transcripts()
  acked = replayed_keys()
  pending: list[dict[str, Any]] = []

  for row in load_jsonl(JOURNAL_FILE):
    key = message_key(row)
    if not key or key in delivered or key in acked:
      continue
    journaled_at = row.get("journaled_at")
    try:
      age = now - int(journaled_at)
    except (TypeError, ValueError):
      age = MIN_AGE_SECONDS
    if age < MIN_AGE_SECONDS:
      continue
    pending.append(row)

  pending.sort(key=lambda r: (str(r.get("meta", {}).get("ts", "")), int(r.get("meta", {}).get("message_id", 0))))
  return pending[:MAX_REPLAY]


def channel_block(row: dict[str, Any]) -> str:
  meta = row.get("meta") if isinstance(row.get("meta"), dict) else {}
  content = str(row.get("content", ""))
  attrs: list[tuple[str, str]] = [("source", "plugin:telegram:telegram"), ("replayed", "claude-tele")]
  for key in [
    "chat_id",
    "message_id",
    "user",
    "user_id",
    "ts",
    "image_path",
    "attachment_kind",
    "attachment_file_id",
    "attachment_size",
    "attachment_mime",
    "attachment_name",
  ]:
    value = meta.get(key)
    if value is not None:
      attrs.append((key, str(value)))
  attr_text = " ".join(f'{k}="{html.escape(v, quote=True)}"' for k, v in attrs)
  body = content.replace("</channel>", "&lt;/channel&gt;")
  return f"<channel {attr_text}>\n{body}\n</channel>"


def write_ack(rows: list[dict[str, Any]]) -> None:
  if not rows:
    return
  ACK_FILE.parent.mkdir(parents=True, exist_ok=True)
  with ACK_FILE.open("a", encoding="utf-8") as f:
    for row in rows:
      f.write(json.dumps(row, ensure_ascii=False, separators=(",", ":")) + "\n")
  ACK_FILE.chmod(0o600)


def tmux_has_session() -> bool:
  return subprocess.run(["tmux", "has-session", "-t", SESSION], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def capture_pane() -> str | None:
  result = subprocess.run(
    ["tmux", "capture-pane", "-t", SESSION, "-p", "-S", "-30"],
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
    text=True,
    check=False,
  )
  if result.returncode != 0 or not result.stdout.strip():
    return None
  return result.stdout


def pane_idle(pane: str) -> bool:
  recent_lines = [line for line in pane.splitlines() if line.strip()][-8:]
  recent = "\n".join(recent_lines)
  if any(re.match(r"^❯\s*$", line) for line in recent_lines[-3:]):
    return True
  if re.search(r"(✻|⏳|↓ [0-9]+ tokens|Cogitat|Thinking|Working|Running tool|Calling |Executing)", recent):
    return False
  if re.search(r"\?|\[y/N\]|Press Enter", recent):
    return False
  return False


def inject(prompt: str) -> None:
  if not tmux_has_session():
    raise RuntimeError(f"tmux session not found: {SESSION}")
  with tempfile.NamedTemporaryFile("w", encoding="utf-8", delete=False) as tmp:
    tmp.write(prompt)
    tmp_path = tmp.name
  try:
    subprocess.run(["tmux", "load-buffer", "-t", SESSION, tmp_path], check=True)
    subprocess.run(["tmux", "paste-buffer", "-t", SESSION], check=True)
    subprocess.run(["tmux", "send-keys", "-t", SESSION, "Enter"], check=True)
  finally:
    try:
      os.unlink(tmp_path)
    except OSError:
      pass


def main() -> int:
  parser = argparse.ArgumentParser(description=__doc__)
  parser.add_argument("--dry-run", action="store_true", help="print pending replay prompt instead of injecting")
  parser.add_argument("--ack", action="store_true", help="mark pending rows as replayed even in dry-run mode")
  args = parser.parse_args()

  rows = pending_rows()
  if not rows:
    print("no missed Telegram messages to replay")
    return 0

  blocks = "\n\n".join(channel_block(row) for row in rows)
  prompt = (
    "Replay missed Telegram messages. These allowed inbound messages were journaled by the "
    "Telegram bridge but are absent from this Claude session transcript. Treat each block as "
    "a normal Telegram channel message, continue from the latest one, and avoid duplicate "
    "responses if you already handled any of them.\n\n"
    f"{blocks}"
  )

  if args.dry_run:
    print(prompt)
  else:
    healthy, reason = telegram_e2e_healthy()
    if not healthy:
      print(f"replay skipped: telegram e2e unhealthy ({reason}); {len(rows)} missed message(s) left pending")
      return 0
    pane = capture_pane()
    if pane is None:
      print(f"replay skipped: pane capture failed; session state unknown; {len(rows)} missed message(s) left pending")
      return 0
    if not pane_idle(pane):
      print(f"replay skipped: session busy; {len(rows)} missed message(s) left pending")
      return 0
    inject(prompt)
    print(f"replayed {len(rows)} missed Telegram message(s) into tmux session {SESSION}")

  if not args.dry_run or args.ack:
    write_ack(rows)
  return 0


if __name__ == "__main__":
  raise SystemExit(main())
