#!/bin/bash
# claude-tele — lifecycle manager for the always-on Telegram Claude channel.
#
# Design (minimal, per Anthropic's plugin architecture):
#   • systemd runs one Claude session: `claude --continue --channels plugin:telegram@claude-plugins-official`
#   • Claude auto-spawns the bun MCP server (.mcp.json) which polls Telegram.
#   • The bun MCP server handles duplicate-poller cleanup itself via
#     ~/.claude/channels/telegram/bot.pid (SIGTERMs any stale holder).
#   • Conversation state persists across restarts via `claude --continue`.
#   • Runs from an isolated workdir so it doesn't hijack your $HOME session.
#
# Rule for the human: never run `claude --channels plugin:telegram…` outside
# this service — a second bun will SIGTERM the systemd one's bun and steal the
# bot token.
#
# Commands:
#   start     Start service (idempotent).
#   stop      Stop service cleanly.
#   restart   Stop + start. Resumes conversation via --continue.
#   status    Service / watchdog / tmux / claude / bun / context meter.
#   attach    tmux attach to the live session.
#   logs [-f] journalctl tail (service + watchdog).
#   heal      Restart service (respawns missing bun). Safe: idempotent.
#   compact [--json] [--force]
#             Safely send /compact to the running Claude session if idle.
#   replay-missed [--dry-run]
#             Inject journaled Telegram messages missing from Claude transcripts.
#   doctor    Preflight diagnostics.
#
# Internal (invoked by systemd):
#   __exec-start   spawn tmux + claude (blocking)
#   __exec-stop    tear it down

set -euo pipefail

readonly SESSION="telegram-claude"
readonly SERVICE="telegram-claude.service"
readonly WATCHDOG_SERVICE="telegram-claude-watchdog.service"
# Resolve claude: prefer ${HOME}/.local/bin/claude (what install.sh links), but
# fall back to whatever is on PATH — common installs land in /usr/local/bin or
# behind a version manager. Avoids a fatal "claude binary missing" on a working
# Claude that simply lives elsewhere.
if [ -x "${HOME}/.local/bin/claude" ]; then
  readonly CLAUDE_BIN="${HOME}/.local/bin/claude"
elif _resolved_claude="$(command -v claude 2>/dev/null)"; then
  readonly CLAUDE_BIN="$_resolved_claude"
else
  readonly CLAUDE_BIN="${HOME}/.local/bin/claude"
fi
readonly STATE_DIR="${HOME}/.claude/channels/telegram"
readonly ENV_FILE="${STATE_DIR}/.env"
readonly TOKEN_KEY_FILE="${STATE_DIR}/.token.key"
readonly TOKEN_ENC_FILE="${STATE_DIR}/.token.enc"
# Dedicated working directory for the telegram Claude session. Keeps its
# conversation transcripts isolated from the user's interactive $HOME session.
readonly WORKDIR="${STATE_DIR}/workdir"
# Plugin's own PID file — written by ~/.claude/plugins/…/telegram/server.ts.
readonly BOT_PID_FILE="${STATE_DIR}/bot.pid"
readonly REPLAY_MISSED_BIN="${HOME}/bin/claude-tele-replay-missed"
readonly WATCHDOG_STATE_FILE="${STATE_DIR}/watchdog.state"
readonly COMPACT_INFLIGHT="${STATE_DIR}/compact.inflight"
readonly COMPACT_SENTINEL_TTL="${CLAUDE_TELE_COMPACT_SENTINEL_TTL:-90}"
readonly HEALTH_FILE="${STATE_DIR}/plugin-health.json"
# Mutex for mutating CLI commands. Prevents user+watchdog races.
readonly CLI_LOCK="${STATE_DIR}/claude-tele.lock"
# Mutex for the systemd ExecStart body — prevents two simultaneous spawns
# (e.g. from daemon-reload + explicit restart) from racing on tmux cleanup.
readonly EXEC_LOCK="${XDG_RUNTIME_DIR:-/tmp}/claude-tele.exec.lock"
readonly TMUX_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/claude-tele"
mkdir -p "$TMUX_RUNTIME_DIR"
chmod 700 "$TMUX_RUNTIME_DIR"
export TMUX_TMPDIR="$TMUX_RUNTIME_DIR"

# ── Output helpers ─────────────────────────────────────────────────────────
# [I-14] Color if stdout OR stderr is a TTY — die/warn write to stderr.
if [ -t 1 ] || [ -t 2 ]; then
  RED=$'\e[31m'; GREEN=$'\e[32m'; YELLOW=$'\e[33m'; BLUE=$'\e[34m'; DIM=$'\e[2m'; RESET=$'\e[0m'
else
  RED=""; GREEN=""; YELLOW=""; BLUE=""; DIM=""; RESET=""
fi
die()  { echo "${RED}error:${RESET} $*" >&2; exit 1; }
warn() { echo "${YELLOW}warn:${RESET} $*" >&2; }
ok()   { echo "${GREEN}✓${RESET} $*"; }
info() { echo "${BLUE}→${RESET} $*"; }

# ── Preflight ──────────────────────────────────────────────────────────────
need() { command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"; }
tmux_cmd() { env -u TMUX tmux "$@"; }

# Read simple KEY=value settings from the bot .env without eval/source.
env_value() {
  local key="$1" default="${2:-}" line value
  [ -r "$ENV_FILE" ] || { printf '%s\n' "$default"; return 0; }
  line=$(grep -E "^${key}=" "$ENV_FILE" 2>/dev/null | tail -1 || true)
  [ -n "$line" ] || { printf '%s\n' "$default"; return 0; }
  value="${line#*=}"
  value="${value%\"}"; value="${value#\"}"
  value="${value%\'}"; value="${value#\'}"
  printf '%s\n' "$value"
}

is_demo() { [ "$(env_value CLAUDE_WATCHDOG_DEMO 0)" = "1" ]; }

decrypt_token() {
  [ -s "$TOKEN_ENC_FILE" ] && [ -s "$TOKEN_KEY_FILE" ] || return 1
  command -v openssl >/dev/null 2>&1 || return 1
  openssl enc -aes-256-cbc -d -pbkdf2 -pass "file:${TOKEN_KEY_FILE}" -in "$TOKEN_ENC_FILE" 2>/dev/null
}

telegram_token() {
  if [ "$(env_value TELEGRAM_BOT_TOKEN_ENCRYPTED 0)" = "1" ]; then
    decrypt_token
    return
  fi
  env_value TELEGRAM_BOT_TOKEN ""
}

permission_mode() {
  local mode
  mode="$(env_value CLAUDE_PERMISSION_MODE bypassPermissions)"
  case "$mode" in
    acceptEdits|auto|bypassPermissions|default|dontAsk|plan) printf '%s\n' "$mode" ;;
    *) warn "invalid CLAUDE_PERMISSION_MODE=${mode}; using default"; printf 'default\n' ;;
  esac
}
need tmux
need systemctl
need flock
[ -x "$CLAUDE_BIN" ] || { is_demo && die "claude binary missing" || die "claude binary missing: $CLAUDE_BIN"; }
mkdir -p "$STATE_DIR" && chmod 700 "$STATE_DIR"

# ── Health predicates ──────────────────────────────────────────────────────
svc_active()     { systemctl --user is-active --quiet "$SERVICE"; }
wd_active()      { systemctl --user is-active --quiet "$WATCHDOG_SERVICE"; }
session_exists() { tmux_cmd has-session -t "$SESSION" 2>/dev/null; }

# [H-3] bun_alive: trust the plugin's own bot.pid. Fall back to `pgrep -x bun`
# + anchored cmdline match, not a bare `pgrep -f substring` which false-matches
# tail/grep/editor invocations of the codebase.
bun_alive() {
  local pid
  if [ -r "$BOT_PID_FILE" ]; then
    pid=$(cat "$BOT_PID_FILE" 2>/dev/null || true)
    if [[ "$pid" =~ ^[0-9]+$ ]] && [ -d "/proc/$pid" ]; then
      [ "$(cat "/proc/$pid/comm" 2>/dev/null || true)" = "bun" ] && return 0
    fi
  fi
  # Fallback: find any bun process whose cmdline contains the plugin path and
  # whose comm is exactly "bun" (rules out scripts/editors matching the path).
  local p
  for p in $(pgrep -x bun 2>/dev/null || true); do
    if tr '\0' ' ' < "/proc/$p/cmdline" 2>/dev/null \
         | grep -qF "claude-plugins-official/telegram"; then
      return 0
    fi
  done
  return 1
}

capture_pane() {
  local pane
  pane=$(tmux_cmd capture-pane -t "$SESSION" -p -S -30 2>/dev/null) || return 1
  [[ "$pane" =~ [^[:space:]] ]] || return 1
  printf '%s\n' "$pane"
}

extract_pct() {
  printf '%s\n' "$1" | grep -aE '[█▌░]' | grep -oE '[0-9]{1,3}%' | tail -1 | tr -d '%' || true
}

# Normalize the prompt's UTF-8 NBSP explicitly so matching works in both the
# service's UTF-8 locale and LC_ALL=C test/recovery shells.
pane_normalize() {
  printf '%s\n' "$1" | sed $'s/\302\240/ /g'
}

pane_has_bare_prompt() {
  pane_normalize "$1" | grep -qE '^❯[[:space:]]*$'
}

# Keep this conservative: reject the TUI's running-turn footer first, then
# require a visible empty input prompt. Unknown renderers, permission dialogs,
# typed drafts, and empty captures fail closed.
pane_idle() {
  local pane="$1"
  local recent
  recent=$(pane_normalize "$pane" | sed '/^[[:space:]]*$/d')
  [ -n "$recent" ] || return 1

  # Busy wins even though Claude keeps the empty input box visible while it runs.
  printf '%s\n' "$recent" | grep -qF 'esc to interrupt' && return 1

  pane_has_bare_prompt "$recent"
}

compact_inflight() {
  [ -f "$COMPACT_INFLIGHT" ] || return 1
  local now mtime age
  now=$(date +%s)
  mtime=$(stat -c %Y "$COMPACT_INFLIGHT" 2>/dev/null) || mtime=0
  age=$((now - mtime))
  if [ "$age" -gt "$COMPACT_SENTINEL_TTL" ]; then
    rm -f "$COMPACT_INFLIGHT"
    return 1
  fi
  return 0
}

telegram_e2e_healthy() {
  [ "${CLAUDE_TELE_DISABLE_E2E_INJECTION_GATE:-0}" = "1" ] && return 0
  python3 - "$HEALTH_FILE" "${CLAUDE_TELE_HEALTH_MAX_AGE:-1200}" <<'PY'
import json, sys, time
from pathlib import Path
path = Path(sys.argv[1])
max_age = int(sys.argv[2])
try:
    health = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(health, dict):
        raise ValueError("invalid health")
except Exception:
    raise SystemExit(1)
now = int(time.time())
def ts(key):
    try:
        return int(health.get(key) or 0)
    except Exception:
        return 0
getme_ok = ts("last_getme_ok_at")
polling_started = ts("polling_started_at")
service_started = ts("service_started_at")
if polling_started <= 0 or getme_ok <= 0 or now - getme_ok > max_age:
    raise SystemExit(1)
if service_started > 0 and polling_started < service_started:
    raise SystemExit(1)
if service_started > 0 and getme_ok < service_started:
    raise SystemExit(1)
if ts("last_getme_error_at") > getme_ok:
    raise SystemExit(1)
notify_ok = ts("last_mcp_notify_ok_at")
notify_err = ts("last_mcp_notify_error_at")
if notify_err > notify_ok:
    raise SystemExit(1)
raise SystemExit(0)
PY
}

# Claude stores transcripts at ~/.claude/projects/<slug>/*.jsonl where the
# slug replaces / with -. [M-7] Derive the slug from WORKDIR instead of
# hardcoding — Anthropic's slugging could change.
workdir_transcript_glob() {
  local slug
  slug="${WORKDIR//\//-}"
  # Claude's project slugging replaces path separators and dots with dashes.
  # Example transcript slug input: ${HOME}/.claude/channels/telegram/workdir
  #   -> -home-ubuntu--claude-channels-telegram-workdir
  slug="${slug//./-}"
  echo "${HOME}/.claude/projects/${slug}/*.jsonl"
}

latest_transcript_file() {
  local glob
  glob=$(workdir_transcript_glob)
  compgen -G "$glob" >/dev/null || return 1
  ls -t $glob 2>/dev/null | head -1
}

claude_auth_failure_present() {
  local pane latest="" pane_file
  pane=$(capture_pane 2>/dev/null || true)
  latest=$(latest_transcript_file 2>/dev/null || true)
  pane_file=$(mktemp "${STATE_DIR}/auth-pane.XXXXXX")
  chmod 600 "$pane_file"
  printf '%s\n' "$pane" > "$pane_file"
  python3 - "$latest" "$pane_file" <<'PY'
import json, re, sys
from pathlib import Path

latest = sys.argv[1]
pane_file = Path(sys.argv[2])
pat = re.compile(r"Please run /login|API Error: 401[^\n]*Invalid authentication credentials", re.I)
try:
    pane = pane_file.read_text(encoding="utf-8", errors="replace")
finally:
    try:
        pane_file.unlink()
    except Exception:
        pass
if pat.search(pane):
    print("pane")
    raise SystemExit(0)

if not latest:
    raise SystemExit(1)
try:
    lines = Path(latest).read_text(encoding="utf-8", errors="replace").splitlines()[-500:]
except Exception:
    raise SystemExit(1)

auth_err = ""
auth_ok = ""
for line in lines:
    try:
        obj = json.loads(line)
    except Exception:
        if pat.search(line):
            auth_err = auth_err or "unknown"
        continue
    ts = str(obj.get("timestamp") or "")
    msg = obj.get("message")
    if not isinstance(msg, dict) or msg.get("role") != "assistant":
        continue
    text = json.dumps(msg.get("content", ""), ensure_ascii=False)
    if pat.search(text):
        auth_err = ts or "unknown"
    elif msg.get("model") and msg.get("model") != "<synthetic>":
        auth_ok = ts or auth_ok

if auth_err and (not auth_ok or auth_err > auth_ok):
    print("transcript")
    raise SystemExit(0)
raise SystemExit(1)
PY
}

claude_auth_failure_in_health() {
  python3 - "$HEALTH_FILE" <<'PY'
import json, sys
from pathlib import Path
try:
    health = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
    if not isinstance(health, dict):
        raise ValueError("invalid health")
except Exception:
    raise SystemExit(1)
def ts(key):
    try:
        return int(health.get(key) or 0)
    except Exception:
        return 0
raise SystemExit(0 if ts("last_claude_auth_error_at") > ts("last_claude_auth_ok_at") else 1)
PY
}

# [M-9] Recursive pane → claude PID walk. Claude may be wrapped by tmux's
# default shell or systemd's exec wrapper; search up to 4 levels deep.
resolve_claude_pid() {
  session_exists || return 1
  local pane_pid
  pane_pid=$(tmux_cmd list-panes -t "$SESSION" -F '#{pane_pid}' 2>/dev/null | head -1)
  [ -n "$pane_pid" ] || return 1
  # BFS through descendants, bail at first comm=="claude".
  local frontier="$pane_pid" next="" depth=0
  while [ -n "$frontier" ] && [ "$depth" -lt 4 ]; do
    next=""
    local pid
    for pid in $frontier; do
      local comm
      comm=$(cat "/proc/$pid/comm" 2>/dev/null || true)
      if [ "$comm" = "claude" ]; then
        echo "$pid"
        return 0
      fi
      next+=" $(pgrep -P "$pid" 2>/dev/null || true)"
    done
    frontier="$next"
    depth=$((depth + 1))
  done
  return 1
}

# ── Internal: executed by systemd ──────────────────────────────────────────
# [H-5] flock-guarded ExecStart so a second __exec-start from a concurrent
# daemon-reload can't race on tmux cleanup. Non-blocking: a duplicate exits
# immediately with a loud log line (systemd will mark the unit failed, which
# is correct — only one instance should be spawning the session).
cmd_exec_start() {
  exec 9>"$EXEC_LOCK"
  flock -n 9 || { echo "exec-start: another spawn is already in progress" >&2; exit 1; }

  if session_exists; then
    warn "stale tmux session '${SESSION}' — killing"
    tmux_cmd kill-session -t "$SESSION" 2>/dev/null || true
  fi

  mkdir -p "$WORKDIR" && chmod 700 "$WORKDIR"
  python3 - "$HEALTH_FILE" <<'PY' || true
import json, sys, time
from pathlib import Path
path = Path(sys.argv[1])
try:
    current = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(current, dict):
        current = {}
except Exception:
    current = {}
now = int(time.time())
current.update({
    "service_started_at": now,
    "polling_started_at": 0,
    "last_mcp_notify_ok_at": 0,
    "last_mcp_notify_error_at": 0,
    "last_error": "service starting",
    "updated_at": now,
})
tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(json.dumps(current, indent=2) + "\n", encoding="utf-8")
tmp.chmod(0o600)
tmp.replace(path)
PY

  # The official Telegram plugin lives in Claude's plugin cache, so updates can
  # replace local fixes. Re-apply the outbound 429/backoff patch before every
  # start so Telegram flood-control never drops chunks silently.
  if [ -x "${HOME}/bin/claude-tele-patch-telegram-plugin" ]; then
    "${HOME}/bin/claude-tele-patch-telegram-plugin"
  else
    warn "telegram plugin patch helper missing; outbound Telegram retry may be absent"
  fi

  # [M-7] Resume previous conversation if a transcript exists for THIS
  # workdir's project slug.
  local resume_flag=""
  local glob
  glob=$(workdir_transcript_glob)
  if compgen -G "$glob" >/dev/null; then
    resume_flag="--continue"
    echo "resuming previous telegram conversation (slug: $(basename "$(dirname "$glob")"))"
  else
    # Warn loudly if neither the expected slug nor ANY transcript exists —
    # catches Anthropic changing the slug encoding silently.
    if compgen -G "${HOME}/.claude/projects/"*"/"*.jsonl >/dev/null 2>&1; then
      warn "no transcript at expected slug — starting fresh (if conversations pile up, slug-encoding may have changed)"
    else
      echo "no prior transcript — starting fresh session"
    fi
  fi

  # Build argv + shell-escape with printf %q. tmux_cmd new-session -c sets the
  # session's cwd to our isolated workdir.
  local mode token
  mode="$(permission_mode)"
  token="$(telegram_token || true)"
  [ -n "$token" ] || die "Telegram bot token missing or encrypted token could not be decrypted"
  local -a argv=("$CLAUDE_BIN")
  if [ "$mode" = "bypassPermissions" ]; then
    argv+=(--dangerously-skip-permissions)
  else
    argv+=(--permission-mode "$mode")
  fi
  [ -n "$resume_flag" ] && argv+=("$resume_flag")
  argv+=(--channels "plugin:telegram@claude-plugins-official")
  local cmd_str
  printf -v cmd_str '%q ' "${argv[@]}"
  TELEGRAM_BOT_TOKEN="$token" tmux_cmd new-session -d -s "$SESSION" -c "$WORKDIR" -- "$cmd_str"
  unset token

  # [M-8] Poll the pane for first-run prompts rather than magic-sleeping.
  # There can be TWO sequential prompts on a fresh session, and we must not
  # break after the first — the bypass-permissions one follows the trust one:
  #
  #   1. Folder-trust. Wording has changed across Claude versions
  #      ("trust the files in this folder" → "Is this a project you created or
  #      one you trust?"). Default highlighted option is "trust", so Enter
  #      accepts.
  #   2. Bypass-permissions warning (only with --dangerously-skip-permissions).
  #      Its default is "No, exit" — pressing Enter would KILL the session.
  #      We must explicitly pick option 2 ("Yes, I accept").
  #
  # Match all known wordings so a Claude UI tweak doesn't silently hang startup.
  local i trust_done=0 bypass_done=0
  for i in $(seq 1 60); do
    local pane
    pane=$(tmux_cmd capture-pane -t "$SESSION" -p -S -40 2>/dev/null || true)
    if [ "$trust_done" = 0 ] && \
       printf '%s\n' "$pane" | grep -qE "trust the files|trust this folder|Is this a project you created"; then
      tmux_cmd send-keys -t "$SESSION" -- Enter   # default option = trust this folder
      echo "folder-trust prompt accepted"
      trust_done=1
      sleep 1
      continue
    fi
    if [ "$bypass_done" = 0 ] && \
       printf '%s\n' "$pane" | grep -q "Bypass Permissions mode"; then
      # Default is "No, exit"; select option 2 "Yes, I accept", then confirm.
      tmux_cmd send-keys -t "$SESSION" -- "2"
      sleep 1
      tmux_cmd send-keys -t "$SESSION" -- Enter
      echo "bypass-permissions prompt accepted"
      bypass_done=1
      sleep 1
      continue
    fi
    # Break once the input prompt "❯" appears (all prompts cleared).
    if pane_has_bare_prompt "$pane"; then
      break
    fi
    sleep 1
  done

  session_exists || { echo "failed to start tmux session" >&2; exit 1; }

  if [ -x "$REPLAY_MISSED_BIN" ]; then
    if replay_output=$("$REPLAY_MISSED_BIN" 2>&1); then
      echo "${replay_output}"
    else
      warn "missed-message replay failed: ${replay_output}"
    fi
  else
    warn "missed-message replay helper missing: ${REPLAY_MISSED_BIN}"
  fi

  echo "started (resume=${resume_flag:-no})"

  # Block until the session dies. systemd tracks THIS process as the unit;
  # when we exit, systemd's Restart= policy applies.
  trap 'echo "exec-start: received signal, exiting"; exit 0' TERM INT
  while session_exists; do
    sleep 5
  done
  echo "tmux session ended — exec-start returning"
}

cmd_exec_stop() {
  session_exists || { echo "already stopped"; return 0; }

  # [M-6] Send SIGINT directly to the claude process instead of typing C-c
  # into tmux — readline may eat keystrokes that looked like "clear input line".
  local cpid
  cpid=$(resolve_claude_pid || true)
  if [ -n "${cpid:-}" ]; then
    echo "sending SIGINT to claude pid ${cpid}"
    kill -INT "$cpid" 2>/dev/null || true
  else
    # Fallback: double-tap C-c into tmux with a brief gap.
    tmux_cmd send-keys -t "$SESSION" -- C-c 2>/dev/null || true
    sleep 0.2
    tmux_cmd send-keys -t "$SESSION" -- C-c 2>/dev/null || true
  fi

  # Wait up to 10s for graceful shutdown (transcript flush).
  local i=0
  while [ "$i" -lt 20 ] && session_exists; do
    sleep 0.5
    i=$((i + 1))
  done

  if session_exists; then
    warn "session did not exit after 10s — force-killing tmux session"
    tmux_cmd kill-session -t "$SESSION" 2>/dev/null || true
    sleep 1
  fi

  if session_exists; then
    echo "ERROR: tmux session still present after kill-session" >&2
    return 1
  fi
  echo "stopped"
}

# ── User-command mutex wrapper ─────────────────────────────────────────────
# [H-2] Serialize mutating commands so user+watchdog don't race. Read-only
# commands (status/attach/logs/doctor/help) do NOT take the lock.
with_cli_lock() {
  exec 8>"$CLI_LOCK"
  if ! flock -w 30 8; then
    die "another claude-tele command is in progress (lock: ${CLI_LOCK})"
  fi
  "$@"
}

# ── User commands ──────────────────────────────────────────────────────────
cmd_start() {
  if svc_active; then
    ok "already running · ${DIM}connect with: claude-tele attach${RESET}"
    return 0
  fi
  info "starting ${SERVICE}…"
  systemctl --user enable --now "$SERVICE"
  sleep 3
  if ! svc_active; then
    systemctl --user status "$SERVICE" --no-pager | head -20 >&2
    die "service failed to activate — run: claude-tele logs"
  fi
  ok "service started"
  # The main unit's Wants= pulls the watchdog up; retain an explicit fallback.
  sleep 1
  if wd_active; then
    ok "watchdog auto-started (main Wants=)"
  else
    info "watchdog not yet active — starting explicitly"
    systemctl --user enable --now "$WATCHDOG_SERVICE" \
      && ok "watchdog started" \
      || warn "watchdog failed — telegram works; auto-compact won't"
  fi
}

cmd_stop() {
  svc_active || { ok "already stopped"; return 0; }
  info "stopping ${SERVICE}…"
  systemctl --user stop "$SERVICE"
  ok "stopped"
  # BindsTo= force-stops the watchdog when main goes inactive.
}

# [H-33 + Obs-A] BindsTo= handles the stop half and the main unit's Wants=
# pulls the watchdog up on start. `systemctl restart` remains atomic, while the
# explicit pull-up below provides insurance if the dependency start failed.
cmd_restart() {
  info "restarting ${SERVICE} (conversation resumes via --continue)…"
  systemctl --user restart "$SERVICE"
  sleep 3
  svc_active || die "restart failed — run: claude-tele logs"
  ok "restarted"
  if ! wd_active; then
    info "watchdog not yet active — starting explicitly"
    systemctl --user enable --now "$WATCHDOG_SERVICE" \
      && ok "watchdog started" \
      || warn "watchdog failed — telegram works; auto-compact won't"
  fi
}

cmd_status() {
  echo "${BLUE}── claude-tele status ──${RESET}"
  is_demo && ok "demo:     on (sensitive details hidden)"
  if svc_active; then ok "service:  ${GREEN}active${RESET}"; else echo "${YELLOW}○ service:  inactive${RESET}"; fi
  if wd_active;  then ok "watchdog: ${GREEN}active${RESET}"; else echo "${YELLOW}○ watchdog: inactive${RESET}"; fi
  if session_exists; then ok "tmux:     '${SESSION}' present"; else echo "${RED}✗ tmux:     '${SESSION}' missing${RESET}"; fi

  # [H-4] Split `local foo=$(...)` into declare + assign on separate lines so
  # subshell exit codes aren't masked under set -e.
  local cpid=""
  if session_exists; then
    cpid=$(resolve_claude_pid 2>/dev/null) || cpid=""
    if [ -n "$cpid" ]; then
      local rss
      rss=$(awk '/VmRSS/ {printf "%.0f MB", $2/1024}' "/proc/${cpid}/status" 2>/dev/null) || rss="?"
      if is_demo; then
        ok "claude:   running (details hidden)"
      else
        ok "claude:   pid ${cpid} · rss ${rss}"
      fi
    else
      echo "${YELLOW}○ claude:   process not found in tmux tree${RESET}"
    fi

    local pane pct
    pane=$(tmux_cmd capture-pane -t "$SESSION" -p -S -15 2>/dev/null) || pane=""
    pct=$(printf '%s\n' "$pane" | grep -aE '[█▌░]' | grep -oE '[0-9]{1,3}%' | tail -1) || pct=""
    [ -n "$pct" ] && ok "context:  ${pct}"
  fi

  if claude_auth_failure_present >/dev/null 2>&1 || { ! session_exists && claude_auth_failure_in_health; }; then
    if is_demo; then
      echo "${RED}✗ claude auth: action required${RESET}"
    else
      echo "${RED}✗ claude auth: expired / API 401 — run /login${RESET}"
      echo "  ${DIM}fix: claude-tele attach, run /login, then verify with dog status${RESET}"
    fi
  else
    ok "claude auth: no 401/login prompt detected"
  fi

  if bun_alive; then
    # Report the PID from bot.pid when available, else the first matching bun.
    local bp=""
    if [ -r "$BOT_PID_FILE" ]; then bp=$(cat "$BOT_PID_FILE" 2>/dev/null) || bp=""; fi
    is_demo && ok "bun:      running (details hidden)" || ok "bun:      pid ${bp:-?} (plugin bridge)"
  else
    if svc_active; then
      echo "${RED}✗ bun:      missing — messages will NOT flow${RESET}"
      echo "  ${DIM}fix: claude-tele heal${RESET}"
    else
      echo "${DIM}○ bun:      not running (service stopped)${RESET}"
    fi
  fi
}

cmd_attach() {
  session_exists || die "session not running · start with: claude-tele start"
  exec env -u TMUX tmux attach -t "$SESSION"
}

# [L-11] Pass follow as a proper array element, not a quoted-empty-string arg.
cmd_logs() {
  local raw=0 follow=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --raw) raw=1 ;;
      -f|--follow) follow=1 ;;
      *) die "unknown logs option: $1" ;;
    esac
    shift
  done
  if is_demo && [ "$raw" != "1" ]; then
    die "demo mode hides logs to avoid leaking prompts, paths, or tokens; use: claude-tele logs --raw"
  fi
  local -a args=(--user -u "$SERVICE" -u "$WATCHDOG_SERVICE" -n 100 --no-pager)
  [ "$follow" = "1" ] && args+=(-f)
  journalctl "${args[@]}"
}

# [M-10 + H-33] Heal ensures the main service is running, relying on its Wants=
# to pull up the watchdog, and restarts main if bun is missing.
cmd_heal() {
  if svc_active && ! bun_alive; then
    warn "service active but bun bridge missing — restarting"
    cmd_restart
    return
  fi
  if ! svc_active; then
    info "service not running — starting"
    cmd_start
    return
  fi
  # Watchdog should be alive via the main unit's Wants=; pull it up if not.
  if ! wd_active; then
    info "watchdog not running — starting"
    systemctl --user enable --now "$WATCHDOG_SERVICE" && ok "watchdog started"
  fi
  ok "nothing to heal"
}

json_result() {
  local ok_value="$1" status="$2" message="$3" context_before="${4:-}"
  python3 - "$ok_value" "$status" "$message" "$context_before" <<'PY'
import json, sys
ok = sys.argv[1] == "true"
payload = {"ok": ok, "status": sys.argv[2], "message": sys.argv[3]}
if sys.argv[4]:
    payload["context_before_pct"] = int(sys.argv[4])
print(json.dumps(payload, indent=2))
PY
}

compact_reply() {
  local json="$1" ok_value="$2" status="$3" message="$4" context_before="${5:-}"
  if [ "$json" = "1" ]; then
    json_result "$ok_value" "$status" "$message" "$context_before"
  elif [ "$ok_value" = "true" ]; then
    ok "$message"
  else
    die "$message"
  fi
}

cmd_compact() {
  local json=0 force=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1 ;;
      --force) force=1 ;;
      *) die "unknown compact option: $1" ;;
    esac
    shift
  done

  if ! session_exists; then
    compact_reply "$json" false "not_running" "tmux session '${SESSION}' is not running"
    return 1
  fi
  if compact_inflight && [ "$force" != "1" ]; then
    compact_reply "$json" false "already_inflight" "compact is already in flight"
    return 1
  fi

  local pane before
  if ! pane=$(capture_pane); then
    compact_reply "$json" false "pane_unavailable" "Claude pane could not be captured; session state is unknown"
    return 1
  fi
  before=$(extract_pct "$pane")
  if ! pane_idle "$pane"; then
    compact_reply "$json" false "busy" "Claude session is busy; not sending /compact" "$before"
    return 1
  fi
  if ! telegram_e2e_healthy; then
    compact_reply "$json" false "telegram_unhealthy" "Telegram E2E health is not fresh; not injecting /compact" "$before"
    return 1
  fi

  local now state_tmp source
  now=$(date +%s)
  state_tmp="${WATCHDOG_STATE_FILE}.tmp"
  source="unknown"
  [ -n "$before" ] && source="meter"
  {
    printf 'context_pct=%s\n' "${before:-unknown}"
    printf 'context_source=%s\n' "$source"
    printf 'last_compact=%s\n' "$now"
    printf 'updated_at=%s\n' "$now"
  } > "$state_tmp"
  chmod 600 "$state_tmp" 2>/dev/null || true
  mv "$state_tmp" "$WATCHDOG_STATE_FILE"
  printf '%s\n' "$now" > "$COMPACT_INFLIGHT"
  tmux_cmd send-keys -t "$SESSION" -- "/compact" Enter
  (
    sleep "$COMPACT_SENTINEL_TTL"
    rm -f "$COMPACT_INFLIGHT"
  ) >/dev/null 2>&1 &

  compact_reply "$json" true "requested" "compact requested" "$before"
}

cmd_replay_missed() {
  [ -x "$REPLAY_MISSED_BIN" ] || die "missing replay helper: ${REPLAY_MISSED_BIN}"
  "$REPLAY_MISSED_BIN" "$@"
}

# [L-12] Replace eval-based check()/soft() with a straight table to avoid
# passing arbitrary strings to eval (internal-only, but sets a bad pattern).
cmd_doctor() {
  echo "${BLUE}── claude-tele doctor ──${RESET}"
  local issues=0

  local_check() {
    local desc="$1" fatal="$2"; shift 2
    if "$@" >/dev/null 2>&1; then
      ok "$desc"
    elif [ "$fatal" = "fatal" ]; then
      echo "${RED}✗ $desc${RESET}"
      issues=$((issues + 1))
    else
      warn "$desc"
    fi
  }

  local_check "tmux installed"                                  fatal  command -v tmux
  local_check "bun runs (plugin runtime; catches AVX2 SIGILL)"  fatal  bun --version
  if is_demo; then
    local_check "claude binary configured"                         fatal  test -x "$CLAUDE_BIN"
  else
    local_check "claude binary at ${CLAUDE_BIN}"                  fatal  test -x "$CLAUDE_BIN"
  fi
  local_check "bot .env present"                                fatal  test -f "${STATE_DIR}/.env"
  local_check "bot .env permissions 600"                        fatal  bash -c "[ \$(stat -c '%a' '${STATE_DIR}/.env' 2>/dev/null) = '600' ]"
  if [ "$(env_value TELEGRAM_BOT_TOKEN_ENCRYPTED 0)" = "1" ]; then
    local_check "encrypted token decrypts"                       fatal  bash -c "'$0' __check-token"
  fi
  local_check "access.json present"                             fatal  test -f "${STATE_DIR}/access.json"
  local_check "access.json permissions 600"                     fatal  bash -c "[ \$(stat -c '%a' '${STATE_DIR}/access.json' 2>/dev/null) = '600' ]"
  local_check "telegram plugin installed"                       fatal  bash -c "compgen -G '${HOME}/.claude/plugins/cache/*/telegram' >/dev/null"
  local_check "service enabled on boot"                         soft   systemctl --user is-enabled --quiet "$SERVICE"
  local_check "watchdog enabled on boot"                        soft   systemctl --user is-enabled --quiet "$WATCHDOG_SERVICE"
  local_check "lingering enabled (survives logout)"                  fatal  bash -c "loginctl show-user \$(id -un) 2>/dev/null | grep -q 'Linger=yes'"

  if claude_auth_failure_present >/dev/null 2>&1 || { ! session_exists && claude_auth_failure_in_health; }; then
    echo "${RED}✗ Claude Code auth check — 401/login prompt detected${RESET}"
    echo "  ${DIM}fix: claude-tele attach, then run /login; watchdog will not restart or auto-login${RESET}"
    issues=$((issues + 1))
  else
    ok "Claude Code auth: no 401/login prompt detected"
  fi

  [ "$issues" -eq 0 ] && ok "all checks passed" || die "${issues} issue(s)"
}

# ── Dispatch ───────────────────────────────────────────────────────────────
# Mutating commands go through the CLI mutex; read-only ones do not.
case "${1:-status}" in
  start)          with_cli_lock cmd_start ;;
  stop)           with_cli_lock cmd_stop ;;
  restart)        with_cli_lock cmd_restart ;;
  heal)           with_cli_lock cmd_heal ;;
  compact)        shift; with_cli_lock cmd_compact "$@" ;;
  replay-missed)  shift; cmd_replay_missed "$@" ;;
  __exec-start)   cmd_exec_start ;;
  __exec-stop)    cmd_exec_stop ;;
  __check-token)  [ -n "$(telegram_token || true)" ] ;;
  status)         cmd_status ;;
  attach)         cmd_attach ;;
  logs)           shift; cmd_logs "$@" ;;
  doctor)         cmd_doctor ;;
  help|-h|--help) sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//' ;;
  *)              die "unknown command: $1 · try: claude-tele help" ;;
esac
